//@version=6
indicator("Ponch Combined", overlay=true, max_lines_count=500, max_labels_count=500)

// ══════════════════════════════════════════════════════════════════════
// SETTINGS
// ══════════════════════════════════════════════════════════════════════

grp_ema = "EMA Channels"
ema1_len = input.int(9, "Inner EMA", group=grp_ema)
ema2_len = input.int(21, "Mid EMA", group=grp_ema)
ema3_len = input.int(55, "Outer EMA", group=grp_ema)
atr_len  = input.int(14, "ATR Length", group=grp_ema)
mult_inner = input.float(1.0, "Inner Multiplier", group=grp_ema)
mult_mid   = input.float(2.5, "Mid Multiplier", group=grp_ema)
mult_outer = input.float(5.0, "Outer Multiplier", group=grp_ema)

grp_vol = "Volatility Levels"
adr_len = input.int(14, "ADR Lookback", group=grp_vol)

grp_mom = "Momentum Scalper"
mom_rsi_len = input.int(14, "Momentum RSI", group=grp_mom)
mom_smooth  = input.int(5, "Momentum Smooth", group=grp_mom)
mom_ob      = input.int(70, "Momentum OB", group=grp_mom)
mom_os      = input.int(30, "Momentum OS", group=grp_mom)

// ══════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ══════════════════════════════════════════════════════════════════════

// Non-repainting historical checks
f_sec(res, expr) => request.security(syminfo.tickerid, res, expr, barmerge.gaps_off, barmerge.lookahead_on)

f_sma_pump() => ta.sma(high - open, adr_len)[1]
f_sma_dump() => ta.sma(open - low, adr_len)[1]
f_max_pump() => ta.highest(high - open, adr_len)[1]
f_max_dump() => ta.highest(open - low, adr_len)[1]

check_cross(curr_h, curr_l, prev_h, prev_l, lvl, is_long) =>
    bool sig = false
    if is_long
        sig := curr_l <= lvl and curr_h >= lvl and prev_l > lvl
    else
        sig := curr_h >= lvl and curr_l <= lvl and prev_h < lvl
    sig

// ══════════════════════════════════════════════════════════════════════
// DAILY / WEEKLY / MONTHLY LEVELS
// ══════════════════════════════════════════════════════════════════════

d_open = request.security(syminfo.tickerid, "D", open)
w_open = request.security(syminfo.tickerid, "W", open)
m_open = request.security(syminfo.tickerid, "M", open)

pdh = f_sec("D", high[1])
pdl = f_sec("D", low[1])

pwh = f_sec("W", high[1])
pwl = f_sec("W", low[1])

pmh = f_sec("M", high[1])
pml = f_sec("M", low[1])

avg_pump = f_sec("D", f_sma_pump())
avg_dump = f_sec("D", f_sma_dump())
max_pump = f_sec("D", f_max_pump())
max_dump = f_sec("D", f_max_dump())

d_res  = d_open + avg_pump
d_sup  = d_open - avg_dump
c_high = d_open + max_pump
c_low  = d_open - max_dump

// ══════════════════════════════════════════════════════════════════════
// RIGHT-SIDE LEVELS DISPLAY (SHORT DASHED LINES)
// ══════════════════════════════════════════════════════════════════════

f_draw_lvl(val, txt, col, style, width, x_off) =>
    var line l = na
    var label lbl = na
    if barstate.islast and not na(val)
        line.delete(l)
        label.delete(lbl)
        l := line.new(bar_index - 15, val, bar_index + 5, val, xloc=xloc.bar_index, color=col, style=style, width=width)
        lbl := label.new(bar_index + x_off, val, txt, xloc=xloc.bar_index, color=color.new(color.black, 100), textcolor=col, style=label.style_label_left, size=size.small)

// Draw Levels with offsets to prevent overlapping
f_draw_lvl(pdh, "PDH", color.gray, line.style_dotted, 1, 6)
f_draw_lvl(pdl, "PDL", color.gray, line.style_dotted, 1, 6)
// --- Combined Open Levels Logic ---
string txt_open = "DO"
color col_open = color.white
bool skip_wo = false
bool skip_mo = false

if d_open == w_open and d_open == m_open
    txt_open := "DO+WO+MO"
    col_open := color.yellow
    skip_wo := true
    skip_mo := true
else if d_open == w_open
    txt_open := "DO+WO"
    col_open := color.fuchsia
    skip_wo := true
else if d_open == m_open
    txt_open := "DO+MO"
    col_open := color.red
    skip_mo := true

f_draw_lvl(d_open, txt_open, col_open, line.style_dotted, 1, 6)

if not skip_wo
    if w_open == m_open
        f_draw_lvl(w_open, "WO+MO", color.purple, line.style_dotted, 1, 6)
        skip_mo := true
    else
        f_draw_lvl(w_open, "WO", color.fuchsia, line.style_dotted, 1, 6)

if not skip_mo
    f_draw_lvl(m_open, "MO", color.red, line.style_dotted, 1, 6)

f_draw_lvl(pwh, "PWH", color.orange, line.style_dotted, 1, 6)
f_draw_lvl(pwl, "PWL", color.blue, line.style_solid, 2, 6)

f_draw_lvl(pmh, "PMH", color.purple, line.style_dotted, 1, 6)
f_draw_lvl(pml, "PML", color.purple, line.style_dotted, 1, 6)

f_draw_lvl(d_res, "Pump", color.red, line.style_solid, 2, 6)
f_draw_lvl(d_sup, "Dump", color.green, line.style_solid, 2, 6)

f_draw_lvl(c_high, "Pump Max", color.orange, line.style_dotted, 1, 6)
f_draw_lvl(c_low, "Dump Max", color.orange, line.style_dotted, 1, 6)

// ══════════════════════════════════════════════════════════════════════
// EMA CHANNELS
// ══════════════════════════════════════════════════════════════════════

atr_val = ta.atr(atr_len)

ema1 = ta.ema(close, ema1_len)
inner_up = ema1 + atr_val * mult_inner
inner_dn = ema1 - atr_val * mult_inner

ema2 = ta.ema(close, ema2_len)
mid_up = ema2 + atr_val * mult_mid
mid_dn = ema2 - atr_val * mult_mid

ema3 = ta.ema(close, ema3_len)
outer_up = ema3 + atr_val * mult_outer
outer_dn = ema3 - atr_val * mult_outer

// p_up1 = plot(inner_up, "Inner Up", color=color.new(color.teal, 70))
// p_dn1 = plot(inner_dn, "Inner Dn", color=color.new(color.teal, 70))
// fill(p_up1, p_dn1, color.new(color.teal, 90), "Inner Band")

// plot(mid_up, "Mid Up", color=color.new(color.teal, 80), linewidth=1)
// plot(mid_dn, "Mid Dn", color=color.new(color.teal, 80), linewidth=1)
plot(outer_up, "Outer Up", color=color.new(color.teal, 60), linewidth=2)
plot(outer_dn, "Outer Dn", color=color.new(color.teal, 60), linewidth=2)

// ══════════════════════════════════════════════════════════════════════
// CHANNEL TRADE SIGNALS (VISUAL ONLY)
// ══════════════════════════════════════════════════════════════════════

// Priority Signal Detection
// Longs: price crossing BELOW bands
bool has_l1 = ta.crossunder(close, inner_dn) 
bool has_l2 = ta.crossunder(close, mid_dn)
bool has_l3 = ta.crossunder(close, outer_dn)

// Shorts: price crossing ABOVE bands
bool has_s1 = ta.crossover(close, inner_up)
bool has_s2 = ta.crossover(close, mid_up)
bool has_s3 = ta.crossover(close, outer_up)

// Hierarchy Logic: Strictly one signal per bar
int sig_type = 0 // 0=None, 1=L+, 2=L++, 3=L+++, -1=S+, -2=S++, -3=S+++
if has_l3
    sig_type := 3
else if has_l2
    sig_type := 2
else if has_l1
    sig_type := 1
else if has_s3
    sig_type := -3
else if has_s2
    sig_type := -2
else if has_s1
    sig_type := -1

// ══════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEPS AND VOLATILITY TOUCHES
// ══════════════════════════════════════════════════════════════════════

touch_pump = check_cross(high, low, high[1], low[1], d_res, false)
touch_dump = check_cross(high, low, high[1], low[1], d_sup, true)
touch_pumpmax = check_cross(high, low, high[1], low[1], c_high, false)
touch_dumpmax = check_cross(high, low, high[1], low[1], c_low, true)

rsi_val = ta.rsi(close, mom_rsi_len)
mom_smooth_val = ta.ema(rsi_val, mom_smooth)

float mom_zone = 0 // 0 = NEUTRAL, 1 = OB, -1 = OS
if mom_smooth_val >= mom_ob
    mom_zone := 1
else if mom_smooth_val <= mom_os
    mom_zone := -1

var int scalp_state = 0 // 0=IDLE, 1=ZONE_ENTRY(LONG), -1=ZONE_ENTRY(SHORT)

bool confirm_long = false
bool confirm_short = false
bool open_long = false
bool open_short = false

// Python Bot Alignment
if scalp_state == 0
    if mom_zone == -1
        scalp_state := 1
        open_long := true
    else if mom_zone == 1
        scalp_state := -1
        open_short := true
else if scalp_state == 1
    if mom_zone == 0
        confirm_long := true
        scalp_state := 0
    else if mom_zone == 1
        scalp_state := -1
        open_short := true
else if scalp_state == -1
    if mom_zone == 0
        confirm_short := true
        scalp_state := 0
    else if mom_zone == -1
        scalp_state := 1
        open_long := true

plotshape(open_long, "MOM Open Long", shape.circle, location.belowbar, color.new(color.yellow, 0), size=size.tiny)
plotshape(open_short, "MOM Open Short", shape.circle, location.abovebar, color.new(color.yellow, 0), size=size.tiny)

// ─── CONFLUENCE LOGIC ───────────────────────────────────────
// (Matches Bot: Only show signals if they have other confirmations)

// 1. Volume Flow Confirm
avg_vol = ta.sma(volume, 20)
bool is_flow_l = close > open and volume > avg_vol * 2.0
bool is_flow_s = close < open and volume > avg_vol * 2.0

// 2. Confluence Checks (Indicators present on current bar)
// For LONG: Channel + (Momentum Confirm OR Sweep OR Flow)
bool conf_l = confirm_long or touch_dump or touch_dumpmax or is_flow_l
// For SHORT: Channel + (Momentum Confirm OR Sweep OR Flow)
bool conf_s = confirm_short or touch_pump or touch_pumpmax or is_flow_s

plotshape(sig_type == 1 and conf_l, "L+", shape.labelup, location.belowbar, color.new(color.green,0), text="L+", textcolor=color.white, size=size.tiny)
plotshape(sig_type == -1 and conf_s, "S+", shape.labeldown, location.abovebar, color.new(color.red,0), text="S+", textcolor=color.white, size=size.tiny)
plotshape(sig_type == 2 and conf_l, "L++", shape.labelup, location.belowbar, color.new(color.green,0), text="L++", textcolor=color.white, size=size.small)
plotshape(sig_type == -2 and conf_s, "S++", shape.labeldown, location.abovebar, color.new(color.red,0), text="S++", textcolor=color.white, size=size.small)
plotshape(sig_type == 3 and conf_l, "L+++", shape.labelup, location.belowbar, color.new(color.green,0), text="L+++", textcolor=color.white, size=size.normal)
plotshape(sig_type == -3 and conf_s, "S+++", shape.labeldown, location.abovebar, color.new(color.red,0), text="S+++", textcolor=color.white, size=size.normal)


// ══════════════════════════════════════════════════════════════════════
// LEVELS TABLE
// ══════════════════════════════════════════════════════════════════════

var table tbl = table.new(position.top_right, 3, 9, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(tbl, 0, 0, "Levels", text_color=color.white, text_halign=text.align_left)
    table.cell(tbl, 1, 0, "Avg Total", text_color=color.white, text_halign=text.align_right)
    table.cell(tbl, 2, 0, "Avg Price", text_color=color.white, text_halign=text.align_right)
    
    table.cell(tbl, 0, 1, "Pump", text_color=color.white, bgcolor=color.new(color.green, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 1, str.tostring(avg_pump, "#.##"), text_color=color.white, text_halign=text.align_right)
    table.cell(tbl, 2, 1, str.tostring(d_open + avg_pump, "#.##"), text_color=color.white, text_halign=text.align_right)

    table.cell(tbl, 0, 2, "Pump, %", text_color=color.white, bgcolor=color.new(color.green, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 2, str.tostring((avg_pump/d_open)*100, "#.##") + "%", text_color=color.white, text_halign=text.align_right)
    
    table.cell(tbl, 0, 3, "Dump", text_color=color.white, bgcolor=color.new(color.red, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 3, str.tostring(avg_dump, "#.##"), text_color=color.white, text_halign=text.align_right)
    table.cell(tbl, 2, 3, str.tostring(d_open - avg_dump, "#.##"), text_color=color.white, text_halign=text.align_right)

    table.cell(tbl, 0, 4, "Dump, %", text_color=color.white, bgcolor=color.new(color.red, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 4, str.tostring((avg_dump/d_open)*100, "#.##") + "%", text_color=color.white, text_halign=text.align_right)
    
    table.cell(tbl, 0, 5, "Volatility", text_color=color.white, bgcolor=color.new(color.orange, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 5, str.tostring(avg_pump+avg_dump, "#.##"), text_color=color.white, text_halign=text.align_right)
    
    table.cell(tbl, 0, 6, "Volatility, %", text_color=color.white, bgcolor=color.new(color.orange, 40), text_halign=text.align_left)
    table.cell(tbl, 1, 6, str.tostring(((avg_pump+avg_dump)/d_open)*100, "#.##") + "%", text_color=color.white, text_halign=text.align_right)

    table.cell(tbl, 0, 7, "Pump Max", text_color=color.white, bgcolor=color.new(color.orange, 50), text_halign=text.align_left)
    table.cell(tbl, 1, 7, str.tostring(max_pump, "#.##"), text_color=color.white, text_halign=text.align_right)
    table.cell(tbl, 2, 7, str.tostring(d_open + max_pump, "#.##"), text_color=color.white, text_halign=text.align_right)

    table.cell(tbl, 0, 8, "Dump Max", text_color=color.white, bgcolor=color.new(color.orange, 50), text_halign=text.align_left)
    table.cell(tbl, 1, 8, str.tostring(max_dump, "#.##"), text_color=color.white, text_halign=text.align_right)
    table.cell(tbl, 2, 8, str.tostring(d_open - max_dump, "#.##"), text_color=color.white, text_halign=text.align_right)
